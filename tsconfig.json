{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "declaration": true,
    "declarationMap": true,
    "outDir": "./dist",
    "rootDir": ".",
    "noEmitOnError": true,
    "resolveJsonModule": true,
    "isolatedModules": true
  },
  "include": [
    "core/**/*",
    "adapters/**/*",
    "apps/workbench/**/*"
  ],
  "exclude": [
    "node_modules",
    "dist",
    "old",
    "apps/workbench-ui",
    "**/*.test.ts",
    "**/*.spec.ts"
  ]
}
