{
  "name": "rune-weaver",
  "version": "0.1.0",
  "description": "自然语言游戏功能编织器",
  "type": "module",
  "bin": {
    "rune-weaver": "./apps/cli/index.ts"
  },
  "scripts": {
    "build": "tsc",
    "check-types": "tsc --noEmit",
    "check:docs": "tsx scripts/check-doc-governance.ts",
    "check:plans": "tsx scripts/check-architecture-plan-consistency.ts",
    "cli": "tsx apps/cli/index.ts",
    "cli:help": "tsx apps/cli/index.ts --help",
    "cli:micro": "tsx apps/cli/index.ts --input \"做一个按Q键的冲刺技能\" --type micro-feature --trigger Q",
    "cli:system": "tsx apps/cli/index.ts --input \"做一个按F4触发的三选一天赋抽取系统\" --type standalone-system --ui",
    "workbench": "tsx apps/workbench/index.ts",
    "test": "tsx core/validation/schema-validator.test.ts && tsx core/llm/config.test.ts && tsx apps/cli/dota2/gap-fill-artifact.test.ts && tsx apps/workbench/workbench-smoke.test.ts && tsx scripts/talent-draw-demo-evidence/refresh-completeness.test.ts",
    "examples": "tsx examples/index.ts",
    "verify:p0": "npm run check-types && npm run test && npm run examples && npm run cli:micro",
    "demo:talent-draw": "tsx scripts/talent-draw-demo-evidence.ts",
    "demo:talent-draw:help": "tsx scripts/talent-draw-demo-evidence.ts --help",
    "demo:talent-draw:refresh": "tsx scripts/talent-draw-demo-evidence/refresh-canonical.ts",
    "demo:talent-draw:lifecycle": "tsx apps/cli/index.ts dota2 lifecycle prove",
    "war3:export-review": "tsx scripts/war3-export-review-package.ts",
    "war3:export-skeleton-demo": "tsx scripts/war3-export-skeleton-demo-package.ts",
    "war3:build-skeleton-probe-input": "tsx scripts/war3-build-skeleton-probe-input.ts",
    "war3:check-probe-summaries": "tsx scripts/war3-check-probe-summary-samples.ts",
    "war3:run-skeleton-demo-probe": "tsx scripts/war3-run-skeleton-demo-probe.ts",
    "war3:summarize-probe-result": "tsx scripts/war3-summarize-probe-result.ts",
    "war3:validate-review": "tsx scripts/war3-validate-review-package.ts",
    "war3:validate-workspace": "tsx scripts/war3-validate-workspace-shape.ts"
  },
  "devDependencies": {
    "@types/node": "^25.5.2",
    "playwright": "^1.59.1",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
